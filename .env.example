# Copy this to .env and fill in real values — never commit .env
API_SECRET=changeme
CACHE_TTL_SECONDS=600

# Non-equity tickers to allow alongside the NASDAQ/NYSE universe (comma-separated)
EXTRA_SYMBOLS=BTC-USD

# Optional. If set, 1-min history is recorded for the 8 most-recently-requested symbols.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional overrides (defaults shown)
# HISTORY_TICK_SECONDS=60
# HISTORY_RETENTION_DAYS=30
# HISTORY_MAX_HOT=8

# Where ticker logos are cached on disk. Relative paths are resolved
# from the project root. Successful logos cache forever; failed lookups
# are remembered for 24h to avoid retry storms.
# LOGO_CACHE_DIR=data/logos
# LOGO_OVERRIDES_FILE=logo_sources.json
